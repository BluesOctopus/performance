# ET_STAGE3_AB_ENABLE_B=1
# ET_STAGE3_AB_FREE_TEXT_MIN_CHARS=24
# ET_STAGE3_AB_FREE_TEXT_MIN_WORDS=4
# ET_STAGE3_AB_B_SIMILARITY_THRESHOLD=0.82
